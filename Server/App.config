<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
  <system.serviceModel>
    <services>
      <service name="Server.Services.ConsumptionService">
        <endpoint
          address="net.tcp://localhost:9000/ConsumptionService"
          binding="netTcpBinding"
          bindingConfiguration="tcpBindingConfig"
          contract="Common.Contracts.IConsumptionService" />
        <host>
          <baseAddresses>
            <add baseAddress="net.tcp://localhost:9000/" />
          </baseAddresses>
        </host>
      </service>
    </services>
    <bindings>
      <netTcpBinding>
        <binding name="tcpBindingConfig"
                 transferMode="Streamed"
                 maxReceivedMessageSize="67108864"
                 maxBufferSize="65536"
                 maxBufferPoolSize="524288">
          <readerQuotas 
              maxDepth="64"
              maxStringContentLength="67108864"
              maxArrayLength="67108864"
              maxBytesPerRead="4096"
              maxNameTableCharCount="16384" />
        </binding>
      </netTcpBinding>
    </bindings>
    <behaviors>
      <serviceBehaviors>
        <behavior>
          <serviceDebug includeExceptionDetailInFaults="true"/>
        </behavior>
      </serviceBehaviors>
    </behaviors>
  </system.serviceModel>
</configuration>